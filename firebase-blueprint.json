{
  "entities": {
    "Issue": {
      "title": "Issue",
      "description": "A reported civic or urban infrastructure issue.",
      "type": "object",
      "properties": {
        "issueId": { "type": "string" },
        "category": { "type": "string" },
        "severity": { "type": "string", "enum": ["Low", "Medium", "High", "Critical"] },
        "description": { "type": "string" },
        "suggestedAction": { "type": "string" },
        "priorityScore": { "type": "integer" },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "status": { "type": "string", "enum": ["Open", "In Progress", "Resolved"] },
        "confirmations": { "type": "integer" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "imageUrl": { "type": "string" },
        "confidence": { "type": "number" },
        "estimatedImpact": { "type": "string" },
        "recommendedResolutionTime": { "type": "string" }
      },
      "required": ["issueId", "category", "severity", "description", "priorityScore", "latitude", "longitude", "status", "confirmations", "createdBy", "createdAt"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "User account profile details.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "displayName", "createdAt"]
    }
  },
  "firestore": {
    "/issues/{issueId}": {
      "schema": "Issue",
      "description": "Public and user-generated civic issue reports."
    },
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "User profile data."
    }
  }
}
